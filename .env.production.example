# =============================================================================
# WrapIQ Production Environment Variables
# Copy this file to .env.production and fill in all values
# =============================================================================

# --- Required: Database ---
DATABASE_URL=postgresql+asyncpg://wrapiq_user:CHANGE_ME@db:5432/wrapiq
POSTGRES_USER=wrapiq_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=wrapiq

# --- Required: Redis ---
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# --- Required: Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME

# --- Required: URLs ---
CORS_ORIGINS=https://your-domain.com
FRONTEND_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# --- Optional: Ports (for docker-compose.prod.yml) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
DB_PORT=5433
REDIS_PORT=6379

# --- Optional: AI (Gemini) ---
GEMINI_API_KEY=

# --- Optional: Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=WrapFlow <noreply@your-domain.com>

# --- Optional: File Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wrapiq-uploads
R2_PUBLIC_URL=
