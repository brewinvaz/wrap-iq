# Required
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/wrapiq
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-key-change-in-production

# Frontend
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Debug
DEBUG=true

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# External Services (optional for local dev)
GEMINI_API_KEY=
RESEND_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wrapiq-uploads
R2_PUBLIC_URL=
EMAIL_FROM=WrapFlow <noreply@wrapflow.io>
